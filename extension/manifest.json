{
  "manifest_version": 3,
  "name": "COps Weather Control",
  "version": "1.0.0",
  "description": "One-click weather settings automation for Bolt Admin Panel",
  "permissions": ["tabs", "scripting"],
  "host_permissions": [
    "https://admin-panel.bolt.eu/*",
    "https://raw.githubusercontent.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://tarasstomin-ua.github.io/COps-work-automatization/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
